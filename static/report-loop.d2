direction: down

inputs: "Receipts + notes\nlogs · links · data" {
  shape: document
}
writer: "Agent writer\ncrafts the story" {
  shape: hexagon
}
mdsvx: "MDSvX page\nprose + components" {
  shape: document
}
review: "wzrrd review URL\nread + steer" {
  shape: rectangle
}
