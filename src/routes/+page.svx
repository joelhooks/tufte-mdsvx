<script lang="ts">
  import FeedbackExport from "$lib/feedback-export.svelte";
  import FeedbackParagraph from "$lib/feedback-paragraph.svelte";
  import FlowChart from "$lib/flow-chart.svelte";
  import MarginNote from "$lib/margin-note.svelte";
  import PatternCards from "$lib/pattern-cards.svelte";
  import ReportLayout from "$lib/ReportLayout.svelte";
  import StatLine from "$lib/stat-line.svelte";

  const pageRef = {
    run: "example-run",
    slug: "tufte-mdsvx-example",
    url: "https://tufte-mdsvx-example.wzrrd.sh/",
    version: "0.1.0",
  };

  const feedbackStoragePrefix = "tufte-mdsvx-feedback:";

  const feedbackParagraphs = [
    "what-this-is",
    "how-agents-use-it",
    "feedback-loop",
    "publish-flow",
  ];

  const stats = [
    { label: "Template", value: "Tufte MDSvX" },
    { label: "Runtime", value: "SvelteKit static" },
    { label: "Feedback", value: "paragraph IDs" },
    { label: "Publish", value: "wzrrd" },
  ];

  const patterns = [
    {
      title: "Narrative first",
      why: "Write the useful story before the evidence dump. Let the page breathe. Use the margin for receipts and caveats.",
      receipts: [{ label: "AGENTS.md", href: "https://github.com/joelhooks/tufte-mdsvx/blob/main/AGENTS.md" }],
    },
    {
      title: "Stable paragraph feedback",
      why: "Wrap important paragraphs in FeedbackParagraph with durable ids. The export button gives agents exact anchors to apply edits later.",
      receipts: [{ label: "feedback", href: "#feedback-export" }],
    },
    {
      title: "Static, shareable, no backend",
      why: "Build static SvelteKit output, then publish ./build to a wzrrd slug. Keep secrets and private receipts out of public bundles.",
      receipts: [{ label: "wzrrd", href: "https://wzrrd.sh/" }],
    },
  ];
</script>

<svelte:head>
  <title>Tufte MDSvX for wzrrd</title>
  <meta
    name="description"
    content="A Tufte-style SvelteKit + MDSvX template for narrative-first wzrrd reports with margin notes and paragraph feedback."
  />
  <meta property="og:title" content="Tufte MDSvX for wzrrd" />
  <meta property="og:description" content="Narrative-first static reports with margin receipts and agent-readable feedback." />
  <meta property="og:image" content="/og.svg" />
  <meta name="twitter:card" content="summary_large_image" />
